# Sistema Pronostici Calcio - Environment Variables
# Copy to .env and fill with your values

# ==================== REQUIRED ====================
# App will not start without these

# Environment (production/development)
FLASK_ENV=production

# The Odds API key for quote reali
# Get your key: https://the-odds-api.com
ODDS_API_KEY=your_api_key_here

# ==================== OPTIONAL ====================
# App uses fallback if missing

# PostgreSQL connection (fallback: CSV tracking)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis cache (fallback: memory cache)
REDIS_URL=redis://localhost:6379/0

# Flask secret key (fallback: auto-generated)
SECRET_KEY=your_secret_key_here

# Server port (fallback: 5000)
PORT=5000
