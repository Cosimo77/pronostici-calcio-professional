# Configurazione Ambiente Enterprise
# File: .env.example (copiare in .env per uso locale)

# ============================================
# CONFIGURAZIONE SICUREZZA
# ============================================

# Secret key per Flask (OBBLIGATORIA in produzione)
# Generare con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secure-secret-key-here

# Ambiente di esecuzione
FLASK_ENV=development  # production per deploy live
FLASK_DEBUG=0  # 1 solo in sviluppo

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Database URL (per upgrade futuro da CSV)
# DATABASE_URL=postgresql://user:password@localhost:5432/pronostici_calcio
# DATABASE_URL=mysql://user:password@localhost:3306/pronostici_calcio
DATABASE_URL=sqlite:///pronostici_calcio.db  # Default SQLite

# ============================================ 
# REDIS CONFIGURATION (Rate Limiting)
# ============================================

# Redis per rate limiting scalabile (produzione)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_SSL=false

# ============================================
# SECURITY SETTINGS
# ============================================

# HTTPS enforcement (true in produzione)
FORCE_HTTPS=false
HTTPS_REDIRECT=false

# CORS settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1

# ============================================
# MONITORING & LOGGING
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Structured logging format
LOG_FORMAT=json  # json or text

# Sentry for error tracking (produzione)
SENTRY_DSN=

# ============================================
# PERFORMANCE TUNING
# ============================================

# Cache TTL in seconds
CACHE_TTL=3600

# Max workers per process
MAX_WORKERS=4

# Request timeout
REQUEST_TIMEOUT=30

# ============================================
# BUSINESS CONFIGURATION
# ============================================

# API rate limits per tier
FREE_TIER_RATE_LIMIT=100/hour
PRO_TIER_RATE_LIMIT=1000/hour
ENTERPRISE_TIER_RATE_LIMIT=10000/hour

# Feature flags
ENABLE_ANALYTICS=true
ENABLE_PREDICTIONS_HISTORY=true
ENABLE_ADVANCED_METRICS=true

# ============================================
# EXTERNAL SERVICES
# ============================================

# Email service (per notifiche)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Payment gateway (futuro)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# DEPLOYMENT
# ============================================

# Port binding
PORT=5008

# Host binding  
HOST=0.0.0.0

# Gunicorn workers (produzione)
GUNICORN_WORKERS=4
GUNICORN_THREADS=2