"""
Test Suite: Cache Manager
Verifica funzionalità caching con Redis fallback su memory
"""

import pytest
import sys
import os
from unittest.mock import Mock, patch, MagicMock
import json

# Add paths
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'web'))

from cache_manager import CacheManager, get_cache_manager


class TestCacheManager:
    """Test CacheManager con Redis fallback su memory cache"""
    
    @pytest.fixture
    def cache_manager(self):
        """Fixture: CacheManager instance con mock Redis"""
        with patch('cache_manager.redis.Redis') as mock_redis:
            # Simula Redis non disponibile per testare memory fallback
            mock_redis.side_effect = Exception("Redis not available")
            manager = CacheManager()
            yield manager
    
    def test_initialization_fallback_to_memory(self, cache_manager):
        """Test: Fallback graceful se Redis non disponibile"""
        # Cache dovrebbe essere disabilitata se Redis non disponibile
        assert cache_manager.enabled is False
        assert cache_manager.redis_client is None
    
    def test_cache_set_and_get_memory(self, cache_manager):
        """Test: Set e get da memory cache"""
        test_key = "test_key"
        test_value = {"squadra": "Inter", "probabilita": 0.65}
        ttl = 3600
        
        # Set
        result = cache_manager._set_cache(test_key, test_value, ttl)
        assert result is True
        
        # Get
        cached_value = cache_manager._get_cache(test_key)
        assert cached_value == test_value
    
    def test_cache_expire_memory(self, cache_manager):
        """Test: TTL expiration su memory cache"""
        import time
        
        test_key = "expire_test"
        test_value = {"data": "test"}
        ttl = 1  # 1 secondo
        
        cache_manager._set_cache(test_key, test_value, ttl)
        
        # Verifica cache hit immediato
        assert cache_manager._get_cache(test_key) == test_value
        
        # Aspetta TTL expiration
        time.sleep(1.1)
        
        # Verifica cache miss dopo expiration
        assert cache_manager._get_cache(test_key) is None
    
    def test_cache_upcoming_matches(self, cache_manager):
        """Test: Caching partite future"""
        mock_data = [
            {"home": "Inter", "away": "Milan", "odds": {"home": 2.1}},
            {"home": "Juve", "away": "Napoli", "odds": {"home": 1.8}}
        ]
        
        # Set cache
        cache_manager.set_upcoming_matches(mock_data)
        
        # Get cache
        cached = cache_manager.cache_upcoming_matches()
        assert cached == mock_data
        assert len(cached) == 2
    
    def test_cache_predictions(self, cache_manager):
        """Test: Caching predizioni ML"""
        match_key = "Inter-Milan-2026-04-02"
        prediction = {
            "home": "Inter",
            "away": "Milan",
            "probabilita": {"1": 0.5, "X": 0.3, "2": 0.2},
            "confidenza": 0.78
        }
        
        # Set
        cache_manager.set_prediction(match_key, prediction)
        
        # Get
        cached = cache_manager.get_prediction(match_key)
        assert cached == prediction
        assert cached["confidenza"] == 0.78
    
    def test_cache_clear_all(self, cache_manager):
        """Test: Clear cache completo"""
        # Popola cache
        cache_manager._set_cache("key1", {"data": 1}, 3600)
        cache_manager._set_cache("key2", {"data": 2}, 3600)
        
        assert len(cache_manager.memory_cache) == 2
        
        # Clear
        cache_manager.clear_cache()
        
        # Verifica cache vuota
        assert len(cache_manager.memory_cache) == 0
        assert cache_manager._get_cache("key1") is None
    
    def test_cache_hit_rate(self, cache_manager):
        """Test: Calcolo hit rate"""
        # Simula hits e misses
        cache_manager._set_cache("cached_key", {"data": "test"}, 3600)
        
        # Hit
        cache_manager._get_cache("cached_key")
        
        # Miss
        cache_manager._get_cache("non_existent_key")
        
        # Verifica almeno 1 hit, 1 miss registrato
        stats = cache_manager.get_cache_stats()
        assert isinstance(stats, dict)
    
    def test_singleton_pattern(self):
        """Test: get_cache_manager ritorna sempre stessa istanza"""
        manager1 = get_cache_manager()
        manager2 = get_cache_manager()
        
        assert manager1 is manager2
    
    def test_cache_invalidation_pattern(self, cache_manager):
        """Test: Pattern invalidazione cache specifica"""
        # Set multiple keys con stesso prefix
        cache_manager._set_cache("match:Inter-Milan", {"data": 1}, 3600)
        cache_manager._set_cache("match:Juve-Napoli", {"data": 2}, 3600)
        cache_manager._set_cache("stats:Inter", {"data": 3}, 3600)
        
        # Verify all cached
        assert cache_manager._get_cache("match:Inter-Milan") is not None
        assert cache_manager._get_cache("stats:Inter") is not None
        
        # Clear only "match:" prefix (simulated pattern)
        keys_to_delete = [k for k in cache_manager.memory_cache.keys() if k.startswith("match:")]
        for key in keys_to_delete:
            del cache_manager.memory_cache[key]
        
        # Verify pattern invalidation
        assert cache_manager._get_cache("match:Inter-Milan") is None
        assert cache_manager._get_cache("stats:Inter") is not None


class TestCacheManagerWithRedis:
    """Test CacheManager con Redis mockato funzionante"""
    
    @pytest.fixture
    def redis_cache_manager(self):
        """Fixture: CacheManager con Redis mock funzionante"""
        with patch('cache_manager.redis.Redis') as mock_redis_class:
            mock_redis = MagicMock()
            mock_redis.ping.return_value = True
            mock_redis.get.return_value = None
            mock_redis.setex.return_value = True
            mock_redis_class.return_value = mock_redis
            
            manager = CacheManager()
            manager.redis_client = mock_redis
            yield manager, mock_redis
    
    def test_redis_set_and_get(self, redis_cache_manager):
        """Test: Set e Get con Redis"""
        manager, mock_redis = redis_cache_manager
        
        test_key = "redis:test"
        test_value = {"squadra": "Inter"}
        
        # Mock Redis get ritorna JSON
        mock_redis.get.return_value = json.dumps(test_value).encode()
        
        # Set
        manager._set_cache(test_key, test_value, 3600)
        
        # Verify Redis setex chiamato
        mock_redis.setex.assert_called_once()
        
        # Get
        cached = manager._get_cache(test_key)
        assert cached == test_value
    
    def test_redis_failure_graceful_degradation(self, redis_cache_manager):
        """Test: Graceful degradation se Redis fallisce"""
        manager, mock_redis = redis_cache_manager
        
        # Simula Redis failure
        mock_redis.get.side_effect = Exception("Redis connection lost")
        
        # Get dovrebbe ritornare None senza crash
        result = manager._get_cache("test_key")
        assert result is None
        
        # Cache dovrebbe essere ancora enabled (fallback a memory)
        assert manager.cache_enabled is True
