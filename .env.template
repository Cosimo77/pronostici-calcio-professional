# CONFIGURAZIONE AMBIENTE PRONOSTICI CALCIO
# Copiare in .env e configurare i valori

# API Keys (opzionali ma raccomandati)
FOOTBALL_DATA_API_TOKEN=your_token_here

# Database (se necessario)
DATABASE_URL=sqlite:///pronostici.db

# Sicurezza
SECRET_KEY=your_secret_key_here

# Configurazione server
FLASK_ENV=production
FLASK_DEBUG=False

# Automazione
ENABLE_AUTOMATION=true
DAILY_UPDATE_TIME=06:00

# Monitoraggio
ENABLE_MONITORING=true
MONITORING_PORT=5001

# Log level
LOG_LEVEL=INFO
